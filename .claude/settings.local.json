{
  "permissions": {
    "allow": [
      "Bash(npx next:*)",
      "Bash(curl -fsSL https://cdn.jsdelivr.net/gh/ruvnet/ruflo@main/scripts/install.sh)",
      "Bash(bash -s -- --full)",
      "Bash(ruflo init:*)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "Bash(ruflo doctor:*)",
      "Bash(claude-flow daemon:*)",
      "Bash(npx ruflo:*)",
      "WebFetch(domain:autosmartweb.cz)",
