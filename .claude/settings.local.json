      "WebFetch(domain:localhost)",
      "Bash(curl -s http://localhost:3000/)",
      "Bash(curl:*)",
      "Read(//tmp/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(npm install:*)",
      "Bash(pnpm add:*)",
      "Bash(npx tsc:*)",
      "mcp__ruflo__system_status",
      "mcp__ruflo__system_health"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "claude-flow"
  ]
