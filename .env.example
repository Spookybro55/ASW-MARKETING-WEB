# =================================================================
# ASW-MARKETING-WEB — Environment variables
# =================================================================
# Copy this file to .env.local for local development.
# In production (Vercel), set these in Project → Settings → Environment Variables.
# Never commit .env or .env.local — only this .env.example with placeholders.

# -----------------------------------------------------------------
# Resend (transactional email provider for /api/contact)
# -----------------------------------------------------------------

# API key from Resend dashboard.
# Get from: https://resend.com/api-keys
# Recommended: "Sending access" permission (least privilege), restricted to verified domain.
# Required: yes (without it, /api/contact returns 500).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender for contact form submissions.
# Format: Display name + email, or just email.
# Domain MUST be verified in Resend Domains tab.
# Preferred: subdomain (protects root domain reputation).
# Example: web@send.autosmartweb.cz
# Alternative: info@autosmartweb.cz (root domain, only if root is verified)
CONTACT_FROM_EMAIL=web@send.autosmartweb.cz

# Recipient — central business inbox per email identity model.
# All form submissions land here.
CONTACT_TO_EMAIL=info@autosmartweb.cz

# -----------------------------------------------------------------
# Notes
# -----------------------------------------------------------------
# - Reply-To is hardcoded to the customer email from the form (src/app/api/contact/route.ts)
#   — no env var needed for that.
# - The site URL is currently hardcoded as "https://autosmartweb.cz" in
#   src/app/layout.tsx and src/app/web-pro-instalatera/page.tsx.
#   No NEXT_PUBLIC_SITE_URL env is read by the runtime.
