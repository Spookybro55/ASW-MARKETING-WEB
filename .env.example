# ===========================================================================
# ASW-MARKETING-WEB — environment variables
# ===========================================================================
# Local dev: copy to .env.local and fill in. .env.local is gitignored.
# Production: set in Vercel → Project Settings → Environment Variables.

# --- Marketing contact form (src/app/api/contact/route.ts) ---
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# --- Google Analytics 4 (gated behind consent — AnalyticsGate) ---
# Measurement ID is a public value; this var just keeps it out of the layout.
# Override per environment (e.g. a separate stream for preview deploys).
NEXT_PUBLIC_GA_ID=

# --- Klientské preview (Service Account read z _previews Sheety) ---
# Hodnoty kopíruj z autosmartweby Vercel projektu (stejný Service Account).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=14U9CC0q5gpFr2p7CD1s4rf3i0lCettIVYIqrO8lsj9c

# Pro lokální dev bez Service Account — preview-reader vrátí mock data
# (test-bauhaus-praha, test-novak-brno, test-svoboda-plzen).
# V produkci je MOCK_MODE ignorován.
# MOCK_MODE=true

# --- Public site URL (used by metadataBase, canonical, OG) ---
# Override per environment (preview / production).
NEXT_PUBLIC_SITE_URL=https://autosmartweb.cz
